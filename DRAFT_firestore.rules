rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId}/analyses/{analysisId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && isValidId(analysisId)
        && request.resource.data.keys().hasAll(['userId', 'idea', 'analysisResult', 'createdAt'])
        && request.resource.data.keys().size() == 4
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.idea is string
        && request.resource.data.idea.size() > 0
        && request.resource.data.idea.size() <= 5000
        && request.resource.data.analysisResult is map
        && request.resource.data.createdAt == request.time;
        
      allow update: if false; // immutable
      allow delete: if false;
    }
  }
}
